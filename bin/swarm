#!/usr/bin/env python3
"""swarm — deterministic ops for the swarm plugin.

Owns: scaffolding (new), scope resolution (here), state files (questions,
approvals), routing (switch, list, status, archive). The orchestrator skill
calls this CLI for anything that must be deterministic; the LLM never edits
state files by hand.
"""
from __future__ import annotations

import argparse
import json
import os
import shutil
import sys
import time
import uuid
from datetime import datetime, timezone
from pathlib import Path

PLUGIN_ROOT = Path(__file__).resolve().parent.parent
TEMPLATES = PLUGIN_ROOT / "templates"
SWARMS_HOME = Path.home() / "swarm"
DEV_HOME = Path.home() / "dev"
GLOBAL_STATE = Path.home() / ".swarm"
ACTIVE_FILE = GLOBAL_STATE / "active.json"


# ----- utils -------------------------------------------------------------- #


def now_iso() -> str:
    return datetime.now(timezone.utc).isoformat()


def read_json(path: Path, default):
    if not path.exists():
        return default
    try:
        return json.loads(path.read_text())
    except json.JSONDecodeError:
        return default


def write_json(path: Path, data) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, indent=2, sort_keys=False) + "\n")


def die(msg: str, code: int = 1) -> None:
    print(f"swarm: {msg}", file=sys.stderr)
    sys.exit(code)


def out(payload, human: str | None = None) -> None:
    """Print as JSON if --json was passed, otherwise human-readable."""
    if PRINT_JSON:
        print(json.dumps(payload, indent=2, sort_keys=False))
    else:
        print(human if human is not None else json.dumps(payload, indent=2))


PRINT_JSON = False  # toggled by --json


# ----- scope resolution --------------------------------------------------- #


def find_swarm_from_cwd(cwd: Path) -> str | None:
    """Walk up from cwd looking for .swarm pointer or .swarm.json marker."""
    p = cwd.resolve()
    for ancestor in [p, *p.parents]:
        pointer = ancestor / ".swarm"
        if pointer.is_file():
            data = read_json(pointer, {})
            if isinstance(data, dict) and data.get("venture"):
                return data["venture"]
        marker = ancestor / ".swarm.json"
        if marker.is_file():
            data = read_json(marker, {})
            if isinstance(data, dict) and data.get("venture"):
                return data["venture"]
    return None


def resolve_active() -> str | None:
    state = read_json(ACTIVE_FILE, {})
    return state.get("active") if isinstance(state, dict) else None


def set_active(name: str) -> None:
    GLOBAL_STATE.mkdir(parents=True, exist_ok=True)
    state = read_json(ACTIVE_FILE, {}) or {}
    state["active"] = name
    state["last_engaged"] = now_iso()
    write_json(ACTIVE_FILE, state)


def swarm_dir(name: str) -> Path:
    return SWARMS_HOME / name


def swarm_exists(name: str) -> bool:
    return (swarm_dir(name) / ".swarm.json").is_file()


# ----- commands ----------------------------------------------------------- #


# Double Diamond phases. Kickoff sets discover; ventures advance via `swarm advance-phase`.
PHASES = ("discover", "define", "develop", "deliver")

# Each phase transition requires an artifact (relative to swarm home) to prove
# the outgoing phase's work is real. Bypass with --force during scaffolding.
PHASE_GATES = {
    ("discover", "define"): "discovery-report.md",
    ("define", "develop"): "venture-brief.md",
    ("develop", "deliver"): "prototype-spec.md",
}

SHAPE_LEAN = {
    "shape": "lean",
    "phase": "discover",
    "leads": ["cos", "founder", "eng-lead", "marketing-lead"],
    "workers": [
        "developer", "copywriter", "researcher", "designer",
        "qa", "reviewer", "instrumentation", "deployer",
    ],
    "skills_per_role": {
        "cos": ["swarm-comms", "swarm-delegate"],
        "founder": ["grilling", "writing-fragments"],
        "eng-lead": ["codebase-design", "code-review", "diagnose", "tdd", "run", "verify"],
        "marketing-lead": ["writing-fragments", "writing-shape", "writing-beats"],
    },
}

DEFAULT_POLICY = {
    "authority": {
        "default": "gated",
        # action types that skip the queue and auto-approve. Only add specific
        # types you've validated (e.g. "staging-deploy" after a few clean runs).
        "auto_approve": [],
    },
    "concurrency": {
        "max_parallel_workers": 3,
        "max_per_lead": 1,
        "worker_timeout_seconds": 900,
    },
    "escalation": {
        "question_escalation_after_hours": 24,
        "approval_escalation_after_hours": 24,
    },
    "tokens": {
        "max_per_swarm_per_day": None,
        "max_per_worker_run": None,
    },
    "delivery": {
        "deploy_targets": {
            "staging": {"gate": "gated", "auto_approve_after_clean_runs": 5},
            "production": {"gate": "gated"},
        },
        "feature_flag_rollout": {
            "auto_approve_at_or_below_percent": 0,
        },
        "external_comms": {
            "auto_approve_at_or_below_recipients": 0,
        },
    },
}


def cmd_new(args) -> None:
    name = args.name
    if not name.replace("-", "").replace("_", "").isalnum():
        die(f"invalid venture name: {name} (use letters, digits, - or _)")
    if swarm_exists(name):
        die(f"swarm '{name}' already exists at {swarm_dir(name)}")

    home = swarm_dir(name)
    home.mkdir(parents=True, exist_ok=True)

    # repo path resolution
    if args.no_repo:
        repo_path = None
    elif args.repo:
        repo_path = str(Path(args.repo).expanduser().resolve())
    else:
        repo_path = str((DEV_HOME / name).resolve())

    # marker
    write_json(home / ".swarm.json", {
        "venture": name,
        "created_at": now_iso(),
        "plugin_version": "0.1.0",
    })

    # shape + policy
    shape = dict(SHAPE_LEAN)
    shape["repo"] = repo_path
    shape["created_at"] = now_iso()
    write_json(home / "shape.json", shape)
    write_json(home / "policy.json", DEFAULT_POLICY)

    # state dirs + files
    (home / "questions").mkdir(exist_ok=True)
    write_json(home / "questions" / "pending.json", [])
    write_json(home / "questions" / "resolved.json", [])

    (home / "approvals").mkdir(exist_ok=True)
    write_json(home / "approvals" / "pending.json", [])
    write_json(home / "approvals" / "resolved.json", [])

    (home / "workers" / "spawned").mkdir(parents=True, exist_ok=True)
    write_json(home / "workers" / "queue.json", [])

    (home / "artifacts").mkdir(exist_ok=True)

    # agents
    persona_src = TEMPLATES / "personas"
    for role in shape["leads"]:
        role_dir = home / "agents" / role
        role_dir.mkdir(parents=True, exist_ok=True)
        (role_dir / "memory").mkdir(exist_ok=True)
        (role_dir / "memory" / "MEMORY.md").write_text(
            f"# {role} memory\n\n_Empty. Topic files appear here as memory accumulates._\n"
        )
        (role_dir / "inbox.md").write_text("# inbox\n\n_No messages._\n")
        src = persona_src / f"{role}.md"
        if src.exists():
            shutil.copy(src, role_dir / "persona.md")
        else:
            (role_dir / "persona.md").write_text(
                f"# {role}\n\n_Persona template not found in plugin._\n"
            )

    # seed brief
    if args.brief:
        (home / "venture-brief-seed.md").write_text(
            f"# seed brief\n\nWritten at /swarm-new time. Kickoff grilling will refine this.\n\n{args.brief}\n"
        )

    # repo init
    repo_status = None
    if repo_path:
        repo_p = Path(repo_path)
        if not repo_p.exists():
            repo_p.mkdir(parents=True, exist_ok=True)
            try:
                import subprocess
                subprocess.run(["git", "init", "-q"], cwd=repo_p, check=False)
                repo_status = "created"
            except FileNotFoundError:
                repo_status = "created_no_git"
        else:
            repo_status = "exists"
        # write .swarm pointer
        write_json(repo_p / ".swarm", {"venture": name, "swarm_home": str(home)})

    # set active
    set_active(name)

    payload = {
        "venture": name,
        "swarm_home": str(home),
        "repo": repo_path,
        "repo_status": repo_status,
        "shape": shape["shape"],
        "leads": shape["leads"],
        "next": "run /swarm-new's kickoff (grilling) to produce venture-brief.md",
    }
    human = (
        f"✓ swarm '{name}' created at {home}\n"
        f"  shape:  {shape['shape']}\n"
        f"  leads:  {', '.join(shape['leads'])}\n"
        f"  repo:   {repo_path or '(no repo)'} ({repo_status or 'n/a'})\n"
        f"  active: now scoped to {name}"
    )
    out(payload, human)


def cmd_here(args) -> None:
    name = find_swarm_from_cwd(Path.cwd())
    source = "cwd"
    if not name:
        name = resolve_active()
        source = "active"
    if not name:
        out({"scoped": False, "reason": "no swarm pinned by cwd, no active swarm"},
            "no swarm in scope. run `/swarm-new <name>` to create one.")
        return
    if not swarm_exists(name):
        out({"scoped": False, "reason": f"active swarm '{name}' does not exist on disk"},
            f"active swarm '{name}' is stale — it does not exist at {swarm_dir(name)}")
        return
    home = swarm_dir(name)
    shape = read_json(home / "shape.json", {})
    pending_q = len(read_json(home / "questions" / "pending.json", []))
    pending_a = len(read_json(home / "approvals" / "pending.json", []))
    payload = {
        "scoped": True,
        "venture": name,
        "source": source,
        "swarm_home": str(home),
        "repo": shape.get("repo"),
        "shape": shape.get("shape"),
        "leads": shape.get("leads", []),
        "pending_questions": pending_q,
        "pending_approvals": pending_a,
    }
    human = (
        f"swarm: {name}  (scoped via {source})\n"
        f"  home:      {home}\n"
        f"  repo:      {shape.get('repo') or '(none)'}\n"
        f"  shape:     {shape.get('shape', '?')}\n"
        f"  leads:     {', '.join(shape.get('leads', []))}\n"
        f"  pending:   {pending_q} questions, {pending_a} approvals"
    )
    out(payload, human)


def cmd_list(args) -> None:
    if not SWARMS_HOME.exists():
        out({"swarms": []}, "no swarms yet. run `/swarm-new <name>` to create one.")
        return
    swarms = []
    for d in sorted(SWARMS_HOME.iterdir()):
        if (d / ".swarm.json").is_file():
            marker = read_json(d / ".swarm.json", {})
            shape = read_json(d / "shape.json", {})
            swarms.append({
                "venture": d.name,
                "created_at": marker.get("created_at"),
                "shape": shape.get("shape"),
                "repo": shape.get("repo"),
            })
    active = resolve_active()
    payload = {"swarms": swarms, "active": active}
    if not swarms:
        human = "no swarms yet."
    else:
        lines = ["swarms:"]
        for s in swarms:
            marker = " *" if s["venture"] == active else "  "
            lines.append(f"{marker} {s['venture']:20s}  shape={s['shape']:12s}  repo={s['repo'] or '(none)'}")
        lines.append("")
        lines.append(f"(* = active)")
        human = "\n".join(lines)
    out(payload, human)


def cmd_switch(args) -> None:
    name = args.name
    if not swarm_exists(name):
        die(f"no swarm '{name}'. run `swarm list` to see options.")
    set_active(name)
    cmd_here(argparse.Namespace())


def cmd_status(args) -> None:
    name = args.name or find_swarm_from_cwd(Path.cwd()) or resolve_active()
    if not name:
        die("no swarm in scope. pass a name or run inside a venture dir.")
    if not swarm_exists(name):
        die(f"no swarm '{name}'.")
    home = swarm_dir(name)
    questions = read_json(home / "questions" / "pending.json", [])
    approvals = read_json(home / "approvals" / "pending.json", [])
    workers_dir = home / "workers" / "spawned"
    active_workers = []
    if workers_dir.exists():
        for d in workers_dir.iterdir():
            if d.is_dir():
                brief = d / "brief.md"
                result = d / "result.md"
                seen = d / "seen.flag"
                state = "done" if result.exists() else "running"
                active_workers.append({
                    "id": d.name,
                    "state": state,
                    "result_seen": seen.exists(),
                })
    payload = {
        "venture": name,
        "pending_questions": questions,
        "pending_approvals": approvals,
        "workers": active_workers,
    }
    lines = [f"swarm: {name}", ""]
    lines.append(f"questions pending ({len(questions)}):")
    for q in questions[:10]:
        lines.append(f"  [{q.get('id')}] from {q.get('from')}: {q.get('question', '')[:80]}")
    if not questions:
        lines.append("  (none)")
    lines.append("")
    lines.append(f"approvals pending ({len(approvals)}):")
    for a in approvals[:10]:
        lines.append(f"  [{a.get('id')}] {a.get('action')} from {a.get('from')}: {a.get('target', '')[:80]}")
    if not approvals:
        lines.append("  (none)")
    lines.append("")
    lines.append(f"workers ({len(active_workers)}):")
    for w in active_workers[:10]:
        flag = "✓" if w["result_seen"] else ("●" if w["state"] == "done" else "…")
        lines.append(f"  {flag} {w['id']}  ({w['state']})")
    if not active_workers:
        lines.append("  (none)")
    out(payload, "\n".join(lines))


def _swarm_for(name_or_none: str | None) -> tuple[str, Path]:
    name = name_or_none or find_swarm_from_cwd(Path.cwd()) or resolve_active()
    if not name:
        die("no swarm in scope. pass --venture or run inside a venture dir.")
    if not swarm_exists(name):
        die(f"no swarm '{name}'.")
    return name, swarm_dir(name)


def _pop_pending(home: Path, queue: str, item_id: str) -> dict | None:
    pending = read_json(home / queue / "pending.json", [])
    for i, item in enumerate(pending):
        if item.get("id") == item_id:
            popped = pending.pop(i)
            write_json(home / queue / "pending.json", pending)
            return popped
    return None


def cmd_answer(args) -> None:
    name, home = _swarm_for(args.venture)
    popped = _pop_pending(home, "questions", args.id)
    if popped is None:
        die(f"no pending question with id '{args.id}'")
    popped["resolved_at"] = now_iso()
    popped["resolution"] = {"pick": args.pick, "note": args.note}
    resolved = read_json(home / "questions" / "resolved.json", [])
    resolved.append(popped)
    write_json(home / "questions" / "resolved.json", resolved)
    out({"resolved": popped}, f"✓ answered {args.id}")


def cmd_approve(args) -> None:
    name, home = _swarm_for(args.venture)
    popped = _pop_pending(home, "approvals", args.id)
    if popped is None:
        die(f"no pending approval with id '{args.id}'")
    popped["resolved_at"] = now_iso()
    popped["resolution"] = {"verdict": "approved", "note": args.note}
    resolved = read_json(home / "approvals" / "resolved.json", [])
    resolved.append(popped)
    write_json(home / "approvals" / "resolved.json", resolved)
    out({"resolved": popped}, f"✓ approved {args.id}")


def cmd_reject(args) -> None:
    name, home = _swarm_for(args.venture)
    popped = _pop_pending(home, "approvals", args.id)
    if popped is None:
        die(f"no pending approval with id '{args.id}'")
    popped["resolved_at"] = now_iso()
    popped["resolution"] = {"verdict": "rejected", "note": args.note}
    resolved = read_json(home / "approvals" / "resolved.json", [])
    resolved.append(popped)
    write_json(home / "approvals" / "resolved.json", resolved)
    out({"resolved": popped}, f"✓ rejected {args.id}")


def cmd_ask(args) -> None:
    """Add a new question to a swarm's pending queue (used by workers/leads)."""
    name, home = _swarm_for(args.venture)
    q = {
        "id": f"q-{uuid.uuid4().hex[:6]}",
        "from": args.from_,
        "spawned": now_iso(),
        "context": args.context or "",
        "question": args.question,
        "options": args.options or [],
    }
    pending = read_json(home / "questions" / "pending.json", [])
    pending.append(q)
    write_json(home / "questions" / "pending.json", pending)
    out({"added": q}, f"✓ question {q['id']} queued")


def cmd_request_approval(args) -> None:
    """Add a new approval to a swarm's pending queue (used by leads/workers)."""
    name, home = _swarm_for(args.venture)
    a = {
        "id": f"a-{uuid.uuid4().hex[:6]}",
        "from": args.from_,
        "spawned": now_iso(),
        "action": args.action,
        "target": args.target or "",
        "preview_path": args.preview_path,
        "irreversible": args.irreversible,
    }
    pending = read_json(home / "approvals" / "pending.json", [])
    pending.append(a)
    write_json(home / "approvals" / "pending.json", pending)
    out({"added": a}, f"✓ approval {a['id']} queued")


def cmd_phase(args) -> None:
    name, home = _swarm_for(args.venture if hasattr(args, "venture") else None)
    shape = read_json(home / "shape.json", {})
    phase = shape.get("phase", "discover")
    payload = {"venture": name, "phase": phase, "phases": list(PHASES)}
    idx = PHASES.index(phase) if phase in PHASES else -1
    marker = " ← current"
    lines = [f"swarm: {name}", f"phase: {phase}", ""]
    for i, p in enumerate(PHASES):
        prefix = "✓" if i < idx else ("●" if i == idx else "·")
        suffix = marker if i == idx else ""
        lines.append(f"  {prefix} {p}{suffix}")
    out(payload, "\n".join(lines))


def cmd_advance_phase(args) -> None:
    name, home = _swarm_for(args.venture)
    shape = read_json(home / "shape.json", {})
    current = shape.get("phase", "discover")
    target = args.target

    if target not in PHASES:
        die(f"unknown phase '{target}'. valid: {', '.join(PHASES)}")

    cur_idx = PHASES.index(current)
    tgt_idx = PHASES.index(target)

    if tgt_idx == cur_idx:
        die(f"already in phase '{current}'")
    if tgt_idx < cur_idx and not args.force:
        die(f"refusing to move backward ({current} → {target}). pass --force if you really mean it.")
    if tgt_idx > cur_idx + 1 and not args.force:
        die(f"refusing to skip phases ({current} → {target}). advance one at a time or pass --force.")

    # gate check — only when advancing one step forward
    if tgt_idx == cur_idx + 1 and not args.force:
        required = PHASE_GATES.get((current, target))
        if required and not (home / required).exists():
            die(
                f"gate failed: {current}→{target} requires artifact '{required}' at {home}. "
                f"Produce it first, or pass --force to bypass."
            )

    shape["phase"] = target
    shape.setdefault("phase_history", []).append({
        "from": current, "to": target, "at": now_iso(),
        "forced": bool(args.force),
    })
    write_json(home / "shape.json", shape)
    payload = {"venture": name, "from": current, "to": target}
    human = (
        f"✓ {name}: {current} → {target}"
        + (f"  (gate: {PHASE_GATES.get((current, target)) or 'none'})" if not args.force else "  (forced)")
    )
    out(payload, human)


def cmd_archive(args) -> None:
    name = args.name
    if not swarm_exists(name):
        die(f"no swarm '{name}'.")
    home = swarm_dir(name)
    archive_root = SWARMS_HOME / ".archive"
    archive_root.mkdir(parents=True, exist_ok=True)
    dest = archive_root / f"{name}-{int(time.time())}"
    shutil.move(str(home), str(dest))
    # clear active if it was this one
    state = read_json(ACTIVE_FILE, {}) or {}
    if state.get("active") == name:
        state["active"] = None
        write_json(ACTIVE_FILE, state)
    out({"archived": name, "dest": str(dest)}, f"✓ archived {name} → {dest}")


# Which memory files travel with each export mode. Missing files are skipped
# silently — venture memory starts empty and fills over time.
EXPORT_MODE_MEMORY = {
    "design": [
        ("founder", "market_thesis.md"),
        ("founder", "customer_insights.md"),
        ("marketing-lead", "positioning.md"),
        ("marketing-lead", "voice.md"),
    ],
    "research": [
        ("founder", "market_thesis.md"),
        ("founder", "customer_insights.md"),
        ("founder", "competitors.md"),
    ],
    "outreach": [
        ("marketing-lead", "positioning.md"),
        ("marketing-lead", "voice.md"),
        ("marketing-lead", "channels.md"),
    ],
    "planning": [
        ("cos", "decisions.md"),
        ("founder", "market_thesis.md"),
        ("eng-lead", "architecture.md"),
        ("marketing-lead", "positioning.md"),
    ],
}

EXPORT_MODE_PROMPT_GUIDE = {
    "design": (
        "You have a venture brief + relevant strategic context. Help me explore "
        "visual/UX directions. Ask clarifying questions if you need. When we converge "
        "on a direction, output a self-contained artifact (React or HTML) I can save."
    ),
    "research": (
        "You have a venture brief + market context. Help me do focused research: "
        "competitor landscape, ICP validation, or a specific open question. Cite sources; "
        "flag disconfirming evidence explicitly."
    ),
    "outreach": (
        "You have positioning, voice, and channel context. Help me draft outbound "
        "material (posts, emails, DMs) that fits the voice and lands the one thing that has to land."
    ),
    "planning": (
        "You have cross-functional context. Help me plan the next chunk of work: "
        "sequence, dependencies, cuttable scope, first thing to ship."
    ),
}


def cmd_export_context(args) -> None:
    name, home = _swarm_for(args.venture)
    mode = args.mode
    if mode not in EXPORT_MODE_MEMORY:
        die(f"unknown mode '{mode}'. valid: {', '.join(EXPORT_MODE_MEMORY)}")

    brief_path = home / "venture-brief.md"
    brief = brief_path.read_text() if brief_path.exists() else "_(no venture-brief.md yet — kickoff hasn't produced one)_"

    parts = [
        f"# Context bundle — {name}",
        f"_Exported {now_iso()} from `{home}`. Mode: **{mode}**._",
        "",
        "## Venture brief",
        brief,
        "",
        "## Relevant memory",
    ]

    included = []
    for role, topic in EXPORT_MODE_MEMORY[mode]:
        path = home / "agents" / role / "memory" / topic
        if path.exists():
            parts.append(f"### `{role}/memory/{topic}`")
            parts.append(path.read_text().rstrip())
            parts.append("")
            included.append(f"{role}/{topic}")
    if not included:
        parts.append("_(no memory topics yet — this venture is early)_")
        parts.append("")

    parts.append("## Prompt guide")
    parts.append(EXPORT_MODE_PROMPT_GUIDE[mode])
    parts.append("")
    parts.append("## Returning to the swarm")
    parts.append(
        "When done, save your winning artifact to a file. Then in the swarm run:\n\n"
        f"```\nswarm import-design <file> --kind {'design' if mode == 'design' else 'note'} \\\n"
        "  --slug <short-name> --summary <optional-summary.md>\n```\n"
    )

    bundle = "\n".join(parts)

    # write / copy / print
    written = None
    copied = False
    if args.out:
        out_path = Path(args.out).expanduser().resolve()
        out_path.parent.mkdir(parents=True, exist_ok=True)
        out_path.write_text(bundle)
        written = str(out_path)
    if args.copy:
        import subprocess
        try:
            subprocess.run(["pbcopy"], input=bundle, text=True, check=True)
            copied = True
        except (FileNotFoundError, subprocess.CalledProcessError):
            print("swarm: --copy failed (pbcopy not available). Printing bundle instead.", file=sys.stderr)
    if not args.out and not args.copy:
        # default: print bundle to stdout so user can pipe
        sys.stdout.write(bundle)
        return

    payload = {
        "venture": name,
        "mode": mode,
        "included_memory": included,
        "written_to": written,
        "copied_to_clipboard": copied,
        "bytes": len(bundle),
    }
    human_lines = [f"✓ exported context for '{name}' (mode: {mode}, {len(bundle):,} bytes)"]
    if written:
        human_lines.append(f"  written to: {written}")
    if copied:
        human_lines.append(f"  copied to clipboard — paste into claude.ai")
    if included:
        human_lines.append(f"  memory included: {', '.join(included)}")
    else:
        human_lines.append("  no memory files yet (venture is early)")
    out(payload, "\n".join(human_lines))


def _slugify(text: str) -> str:
    import re
    slug = re.sub(r"[^a-z0-9]+", "-", text.lower()).strip("-")
    return slug or "artifact"


def cmd_import_design(args) -> None:
    name, home = _swarm_for(args.venture)
    src = Path(args.source).expanduser().resolve()
    if not src.exists():
        die(f"source file not found: {src}")

    kind = args.kind
    if kind not in ("design", "research", "note"):
        die(f"unknown kind '{kind}'. valid: design, research, note")

    slug = args.slug or _slugify(src.stem)
    ts = int(time.time())
    ext = src.suffix or ".txt"

    dest_dir = home / "artifacts" / kind
    dest_dir.mkdir(parents=True, exist_ok=True)
    dest = dest_dir / f"{slug}-{ts}{ext}"
    shutil.copy(src, dest)

    # summary handling
    summary_dest = dest_dir / f"{slug}-{ts}.md"
    if args.summary:
        summary_src = Path(args.summary).expanduser().resolve()
        if not summary_src.exists():
            die(f"summary file not found: {summary_src}")
        shutil.copy(summary_src, summary_dest)
        summary_status = "provided"
    else:
        summary_dest.write_text(
            f"# {slug} — imported {datetime.now(timezone.utc).date().isoformat()}\n\n"
            f"_Kind: {kind}. Source: `{src.name}` → `{dest.name}`._\n\n"
            "## Why this direction won\n_TBD — fill this in._\n\n"
            "## What we rejected and why\n_TBD._\n\n"
            "## Open decisions for the developer/lead\n_TBD._\n"
        )
        summary_status = "stub_created"

    # suggested next-step brief for the orchestrator to consume
    next_step = {
        "design": (
            f"Spawn swarm-designer with brief pointing at:\n"
            f"  artifact: {dest}\n"
            f"  summary:  {summary_dest}\n"
            f"Task: produce a structured design spec (flows, states, edge cases) "
            f"that a developer can implement from. Reference the imported direction."
        ),
        "research": (
            f"Spawn a lead consultation (Founder or Marketing) to react to:\n"
            f"  research: {dest}\n"
            f"  summary:  {summary_dest}\n"
            f"Task: extract implications for thesis/positioning; propose memory updates."
        ),
        "note": (
            f"Read the imported note and decide the next move:\n"
            f"  note: {dest}\n"
            f"  summary: {summary_dest}"
        ),
    }[kind]

    payload = {
        "venture": name,
        "kind": kind,
        "slug": slug,
        "artifact_path": str(dest),
        "summary_path": str(summary_dest),
        "summary_status": summary_status,
        "next_step_hint": next_step,
    }
    lines = [
        f"✓ imported '{src.name}' → artifacts/{kind}/",
        f"  artifact: {dest}",
        f"  summary:  {summary_dest} ({summary_status})",
        "",
        "Next step:",
        next_step,
    ]
    out(payload, "\n".join(lines))


# ----- main --------------------------------------------------------------- #


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="swarm", description="swarm plugin CLI")
    p.add_argument("--json", action="store_true", help="emit JSON instead of human text")
    sub = p.add_subparsers(dest="cmd", required=True)

    s = sub.add_parser("new", help="scaffold a new swarm")
    s.add_argument("name")
    s.add_argument("--shape", default="lean")
    s.add_argument("--brief", default=None)
    s.add_argument("--repo", default=None, help="path to product repo (default: ~/dev/<name>)")
    s.add_argument("--no-repo", action="store_true", help="skip product repo creation")
    s.set_defaults(func=cmd_new)

    s = sub.add_parser("here", help="show scoped venture (cwd → active fallback)")
    s.set_defaults(func=cmd_here)

    s = sub.add_parser("list", help="list all swarms")
    s.set_defaults(func=cmd_list)

    s = sub.add_parser("switch", help="set active swarm")
    s.add_argument("name")
    s.set_defaults(func=cmd_switch)

    s = sub.add_parser("status", help="show pending queues and worker state")
    s.add_argument("name", nargs="?")
    s.set_defaults(func=cmd_status)

    s = sub.add_parser("answer", help="resolve a pending question")
    s.add_argument("id")
    s.add_argument("--pick", default=None)
    s.add_argument("--note", default=None)
    s.add_argument("--venture", default=None)
    s.set_defaults(func=cmd_answer)

    s = sub.add_parser("approve", help="approve a pending action")
    s.add_argument("id")
    s.add_argument("--note", default=None)
    s.add_argument("--venture", default=None)
    s.set_defaults(func=cmd_approve)

    s = sub.add_parser("reject", help="reject a pending action")
    s.add_argument("id")
    s.add_argument("--note", default=None)
    s.add_argument("--venture", default=None)
    s.set_defaults(func=cmd_reject)

    s = sub.add_parser("ask", help="add a question to pending queue")
    s.add_argument("question")
    s.add_argument("--from", dest="from_", required=True)
    s.add_argument("--context", default=None)
    s.add_argument("--options", nargs="*", default=None)
    s.add_argument("--venture", default=None)
    s.set_defaults(func=cmd_ask)

    s = sub.add_parser("request-approval", help="add an approval to pending queue")
    s.add_argument("action")
    s.add_argument("--from", dest="from_", required=True)
    s.add_argument("--target", default=None)
    s.add_argument("--preview-path", default=None)
    s.add_argument("--irreversible", action="store_true")
    s.add_argument("--venture", default=None)
    s.set_defaults(func=cmd_request_approval)

    s = sub.add_parser("phase", help="show current Double Diamond phase")
    s.add_argument("--venture", default=None)
    s.set_defaults(func=cmd_phase)

    s = sub.add_parser("export-context", help="bundle brief + memory for claude.ai roundtrip")
    s.add_argument("--for", dest="mode", default="design",
                   choices=list(EXPORT_MODE_MEMORY.keys()),
                   help="context flavor (default: design)")
    s.add_argument("--out", default=None, help="write bundle to a file")
    s.add_argument("--copy", action="store_true", help="copy bundle to clipboard (macOS: pbcopy)")
    s.add_argument("--venture", default=None)
    s.set_defaults(func=cmd_export_context)

    s = sub.add_parser("import-design", help="bring a claude.ai artifact back into the swarm")
    s.add_argument("source", help="path to the artifact file (e.g. an exported .tsx or .html)")
    s.add_argument("--kind", default="design", choices=["design", "research", "note"],
                   help="artifact type (default: design)")
    s.add_argument("--slug", default=None, help="short name for the artifact (defaults to source stem)")
    s.add_argument("--summary", default=None,
                   help="path to a markdown summary; if omitted, a stub is created")
    s.add_argument("--venture", default=None)
    s.set_defaults(func=cmd_import_design)

    s = sub.add_parser("advance-phase", help="advance to next Double Diamond phase (with gate)")
    s.add_argument("target", choices=list(PHASES))
    s.add_argument("--force", action="store_true", help="bypass artifact gate")
    s.add_argument("--venture", default=None)
    s.set_defaults(func=cmd_advance_phase)

    s = sub.add_parser("archive", help="archive a swarm")
    s.add_argument("name")
    s.set_defaults(func=cmd_archive)

    return p


def main(argv: list[str]) -> None:
    global PRINT_JSON
    parser = build_parser()
    args = parser.parse_args(argv)
    PRINT_JSON = args.json
    args.func(args)


if __name__ == "__main__":
    main(sys.argv[1:])
